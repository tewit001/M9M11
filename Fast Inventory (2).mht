@charset "utf-8";

@import url("https://fonts.googleapis.com/css2?family=Barlow:wght@400;500;600;700;800;900&family=Barlow+Condensed:wght@700;800;900&family=DM+Mono:wght@400;500&display=swap");

*, ::before, ::after { box-sizing: border-box; -webkit-tap-highlight-color: transparent; }

body { overscroll-behavior: none; margin: 0px; }

::-webkit-scrollbar { display: none; }

@keyframes flashPop { 
  0% { opacity: 0; transform: scale(0.88); }
  70% { transform: scale(1.04); }
  100% { opacity: 1; transform: scale(1); }
}

@keyframes slideUp { 
  0% { opacity: 0; transform: translateY(16px); }
  100% { opacity: 1; transform: translateY(0px); }
}

@keyframes expGlow { 
  0%, 100% { box-shadow: rgba(251, 191, 36, 0) 0px 0px 0px 0px; }
  50% { box-shadow: rgba(251, 191, 36, 0.28) 0px 0px 28px 6px; }
}

@keyframes rowPop { 
  0% { background: rgba(129, 140, 248, 0.2); }
  100% { background: transparent; }
}

@keyframes spin { 
  100% { transform: rotate(360deg); }
}

input[type="number"]::-webkit-inner-spin-button { appearance: none; }

.slide-up { animation: 0.22s ease 0s 1 normal none running slideUp; }

.exp-glow { animation: 2.2s ease-in-out 0s infinite normal none running expGlow; }

.row-pop { animation: 2.5s ease 0s 1 normal forwards running rowPop; }
